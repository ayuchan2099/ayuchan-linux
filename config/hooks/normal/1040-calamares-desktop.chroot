#!/bin/bash
# 安装器：自动配置 squashfs 路径 + 图形/文本安装入口
set -e

install -d /usr/local/bin /etc/sudoers.d /etc/polkit-1/rules.d

cat > /usr/local/bin/ayuchan-configure-calamares << 'EOF'
#!/bin/bash
# 以 root 运行：检测 Live squashfs 并写入 unpackfs.conf
set -e
SQUASH=""
for p in \
  /run/live/medium/live/filesystem.squashfs \
  /lib/live/mount/medium/live/filesystem.squashfs \
  /live/filesystem.squashfs; do
  if [ -f "$p" ]; then
    SQUASH="$p"
    break
  fi
done
if [ -z "$SQUASH" ]; then
  for base in /run/live/medium /lib/live/mount/medium; do
    if [ -d "$base" ]; then
      found="$(find "$base" -maxdepth 4 -name 'filesystem.squashfs' -type f 2>/dev/null | head -1)"
      if [ -n "$found" ]; then
        SQUASH="$found"
        break
      fi
    fi
  done
fi
if [ -z "$SQUASH" ]; then
  echo "错误: 未找到 Live squashfs 镜像" >&2
  exit 1
fi
mkdir -p /etc/calamares/modules
cat > /etc/calamares/modules/unpackfs.conf << CONF
---
unpack:
    - source: "$SQUASH"
      sourcefs: "squashfs"
      destination: ""
CONF
echo "Calamares unpackfs -> $SQUASH"
EOF
chmod 755 /usr/local/bin/ayuchan-configure-calamares

cat > /usr/local/bin/ayuchan-install-check << 'EOF'
#!/bin/bash
echo "=== Ayuchan 安装诊断 ==="
echo "用户: $(id -un)  DISPLAY=${DISPLAY:-未设置}"
for p in \
  /run/live/medium/live/filesystem.squashfs \
  /lib/live/mount/medium/live/filesystem.squashfs \
  /lib/live/mount/medium/install/initrd.gz \
  /run/live/medium/install/initrd.gz; do
  if [ -e "$p" ]; then echo "[OK] $p"; else echo "[--] $p"; fi
done
echo "---"
command -v calamares >/dev/null && calamares --version 2>/dev/null | head -1 || echo "calamares: 未安装"
command -v debian-installer-launcher >/dev/null && echo "debian-installer-launcher: OK" || echo "debian-installer-launcher: 未安装"
echo "--- settings.conf ---"
if [ -f /etc/calamares/settings.conf ]; then
  grep -E '^(instance|branding|module-config):' /etc/calamares/settings.conf
  if grep -q '^sequence:' /etc/calamares/settings.conf; then
    echo "[OK] settings.conf 含 sequence（Calamares 必需）"
  else
    echo "[!!] settings.conf 缺少 sequence — Calamares 会报 fatal: no sequence set"
  fi
else
  echo "[!!] 未找到 /etc/calamares/settings.conf"
fi
[ -f /etc/calamares/modules/unpackfs.conf ] && echo "--- unpackfs.conf ---" && cat /etc/calamares/modules/unpackfs.conf
echo "--- 建议 ---"
echo "图形安装: ayuchan-install-gui"
echo "文本安装: ayuchan-install-text  或 GRUB 菜单选 Install"
EOF
chmod 755 /usr/local/bin/ayuchan-install-check

cat > /usr/local/bin/ayuchan-install-check-wait << 'EOF'
#!/bin/bash
/usr/local/bin/ayuchan-install-check
echo
read -r -p "按回车关闭..." _
EOF
chmod 755 /usr/local/bin/ayuchan-install-check-wait

cat > /usr/local/bin/ayuchan-install-check-term << 'EOF'
#!/bin/bash
export DISPLAY="${DISPLAY:-:0}"
exec xfce4-terminal --hold -T "Install Check" -e /usr/local/bin/ayuchan-install-check-wait
EOF
chmod 755 /usr/local/bin/ayuchan-install-check-term

cat > /usr/local/bin/ayuchan-install-text-term << 'EOF'
#!/bin/bash
export DISPLAY="${DISPLAY:-:0}"
exec xfce4-terminal --hold -T "Text Install" -e /usr/local/bin/ayuchan-install-text
EOF
chmod 755 /usr/local/bin/ayuchan-install-text-term

cat > /usr/local/bin/ayuchan-install-gui << 'EOF'
#!/bin/bash
export DISPLAY="${DISPLAY:-:0}"
export XDG_RUNTIME_DIR="${XDG_RUNTIME_DIR:-/run/user/$(id -u)}"
mkdir -p "$XDG_RUNTIME_DIR"
chmod 700 "$XDG_RUNTIME_DIR"
LOG="${HOME}/.local/share/ayuchan/calamares.log"
mkdir -p "$(dirname "$LOG")"

if ! xset q >/dev/null 2>&1 && ! xdpyinfo >/dev/null 2>&1; then
  /usr/local/bin/ayuchan-install-check-term
  exit 1
fi

if ! sudo /usr/local/bin/ayuchan-configure-calamares; then
  zenity --error --text="未找到 Live 系统镜像 (squashfs)。\n请运行: ayuchan-install-check" 2>/dev/null \
    || /usr/local/bin/ayuchan-install-check-term
  exit 1
fi

calamares 2>&1 | tee "$LOG"
status=${PIPESTATUS[0]}
if [ "$status" -ne 0 ]; then
  zenity --error --text="Calamares 启动失败 (代码 $status)\n日志: $LOG" 2>/dev/null \
    || xfce4-terminal -e "echo 安装器失败; tail -20 '$LOG'; read"
fi
exit "$status"
EOF
chmod 755 /usr/local/bin/ayuchan-install-gui

cat > /usr/local/bin/ayuchan-install-text << 'EOF'
#!/bin/bash
export DISPLAY="${DISPLAY:-:0}"
INITRD=""
for p in /lib/live/mount/medium/install/initrd.gz /run/live/medium/install/initrd.gz; do
  [ -f "$p" ] && INITRD="$p" && break
done
if [ -z "$INITRD" ]; then
  zenity --error --text="未找到 Debian 文本安装器 (initrd.gz)\n请从 GRUB 菜单选 Install 启动" 2>/dev/null \
    || { echo "未找到 initrd.gz"; ayuchan-install-check; }
  exit 1
fi
exec sudo /usr/bin/debian-installer-launcher
EOF
chmod 755 /usr/local/bin/ayuchan-install-text

cat > /etc/sudoers.d/ayuchan-install << 'EOF'
Defaults:ayuchan !requiretty
ayuchan ALL=(ALL) NOPASSWD: /usr/local/bin/ayuchan-configure-calamares
ayuchan ALL=(ALL) NOPASSWD: /usr/bin/debian-installer-launcher, /usr/sbin/debian-installer-launcher
EOF
chmod 440 /etc/sudoers.d/ayuchan-install

install -d /usr/share/applications

cat > /usr/share/applications/ayuchan-install-gui.desktop << 'EOF'
[Desktop Entry]
Type=Application
Version=1.0
Name=Install Ayuchan Linux
Name[zh_CN]=安装 Ayuchan Linux
Comment=Graphical installer (Calamares)
Comment[zh_CN]=图形安装器 Calamares
Icon=calamares
Exec=/usr/local/bin/ayuchan-install-gui
Terminal=false
Categories=System;
StartupNotify=true
EOF

cat > /usr/share/applications/ayuchan-install-text.desktop << 'EOF'
[Desktop Entry]
Type=Application
Version=1.0
Name=Text Install Ayuchan Linux
Name[zh_CN]=文本安装 Ayuchan Linux
Comment=Debian text installer
Comment[zh_CN]=Debian 文本安装器
Icon=debian-installer
Exec=/usr/local/bin/ayuchan-install-text-term
Terminal=false
Categories=System;
StartupNotify=true
EOF

cat > /usr/share/applications/ayuchan-install-check.desktop << 'EOF'
[Desktop Entry]
Type=Application
Version=1.0
Name=Check Install Environment
Name[zh_CN]=安装环境诊断
Comment=Diagnose installer paths
Icon=utilities-terminal
Exec=/usr/local/bin/ayuchan-install-check-term
Terminal=false
Categories=System;
EOF

for desk in /etc/skel/Desktop /home/ayuchan/Desktop; do
  install -d "$desk"
  cp /usr/share/applications/ayuchan-install-gui.desktop "$desk/Install Ayuchan Linux.desktop"
  cp /usr/share/applications/ayuchan-install-text.desktop "$desk/Text Install Ayuchan Linux.desktop"
  cp /usr/share/applications/ayuchan-install-check.desktop "$desk/Install Check.desktop"
  chmod +x "$desk/"*.desktop
done

if id ayuchan >/dev/null 2>&1; then
  chown -R ayuchan:ayuchan /home/ayuchan/Desktop 2>/dev/null || true
fi

install -d /etc/xdg/autostart
cat > /etc/xdg/autostart/ayuchan-trust-desktop.desktop << 'EOF'
[Desktop Entry]
Type=Application
Name=Trust Ayuchan Desktop Launchers
Exec=sh -c 'sleep 8; for f in "$HOME/Desktop/"*.desktop; do [ -f "$f" ] && gio set "$f" metadata::trusted true 2>/dev/null; chmod +x "$f"; done'
Hidden=true
NoDisplay=true
X-GNOME-Autostart-enabled=true
OnlyShowIn=XFCE;
EOF

cat > /etc/xdg/autostart/ayuchan-calamares.desktop << 'EOF'
[Desktop Entry]
Type=Application
Name=Calamares Auto Install
Exec=sh -c 'grep -qs ayuchan-install=1 /proc/cmdline && sleep 10 && ayuchan-install-gui'
Hidden=true
NoDisplay=true
X-GNOME-Autostart-enabled=true
OnlyShowIn=XFCE;
EOF

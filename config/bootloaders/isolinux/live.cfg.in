label live-@FLAVOUR@
	menu label ^Live system (try Ayuchan Linux)
	menu default
	linux @LINUX@
	initrd @INITRD@
	append @APPEND_LIVE@

label live-@FLAVOUR@-install
	menu label ^Live install (start Calamares)
	linux @LINUX@
	initrd @INITRD@
	append @APPEND_LIVE@ ayuchan-install=1

label live-@FLAVOUR@-failsafe
	menu label ^Live (failsafe / nomodeset)
	linux @LINUX@
	initrd @INITRD@
	append @APPEND_LIVE_FAILSAFE@

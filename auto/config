#!/bin/bash
set -e

lb config noauto \
  --mode debian \
  --architectures amd64 \
  --distribution bookworm \
  --linux-flavours amd64 \
  --debian-installer false \
  --binary-images iso-hybrid \
  --apt-indices false \
  --memtest none \
  --iso-application "Ayuchan Linux Live" \
  --iso-preparer "ayuchan" \
  --iso-publisher "ayuchan" \
  --win32-loader false \
  --bootappend-live "boot=live components quiet splash live-media=removable i915.enable_psr=0 i915.enable_fbc=0" \
  --bootappend-live-failsafe "boot=live components nomodeset i915.enable_psr=0 live-media=removable" \
  --archive-areas "main contrib non-free non-free-firmware"

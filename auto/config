#!/bin/bash
set -e

lb config noauto \
  --mode debian \
  --architectures amd64 \
  --distribution bookworm \
  --linux-flavours amd64 \
  --debian-installer false \
  --binary-images iso-hybrid \
  --apt-indices false \
  --memtest none \
  --iso-application "Ayuchan Linux Live" \
  --iso-preparer "ayuchan" \
  --iso-publisher "ayuchan" \
  --win32-loader false \
  --bootappend-live "boot=live components live-media=removable nomodeset i915.enable_psr=0 i915.enable_fbc=0 nvidia.modeset=0 nosplash loglevel=3" \
  --bootappend-live-failsafe "boot=live components live-media=removable nomodeset i915.enable_psr=0 nvidia.modeset=0 libata.noapm=1 nosplash single" \
  --archive-areas "main contrib non-free non-free-firmware"
